    "efficiency": {
      "type": "string",
      "title": "Efficiency (%)"
    },
    "warranty_years": {
      "type": "number",
      "title": "Warranty (Years)"
    },
    "weight": {
      "type": "string",
      "title": "Weight"
    },
    "dimensions": {
      "type": "string",
      "title": "Dimensions"
    },
    "features": {
      "type": "array",
      "title": "Features",
      "items": {
        "type": "string"
      }
    },
    "in_stock": {
      "type": "boolean",
      "title": "In Stock",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "title": "Featured",
      "default": false
    },
    "rating": {
      "type": "number",
      "title": "Rating"
    },
    "review_count": {
      "type": "number",
      "title": "Review Count"
    }
