{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Product Name"
    },
    "slug": {
      "type": "string",
      "title": "URL Slug"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "short_description": {
      "type": "string",
      "title": "Short Description"
    },
    "price": {
      "type": "number",
      "title": "Price"
    },
    "original_price": {
      "type": "number",
      "title": "Original Price"
    },
    "category": {
      "type": "string",
      "title": "Category",
